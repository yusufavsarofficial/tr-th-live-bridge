{
  "expo": {
    "name": "Sevgilim Chat",
    "slug": "sevgilim-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "sevgilimchat",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.sevgilimchat.android",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "plugins": [
      "@config-plugins/react-native-webrtc",
      [
        "expo-camera",
        {
          "cameraPermission": "Goruntulu gorusme icin kamera izni gerekir.",
          "microphonePermission": "Sesli mesaj ve gorusme icin mikrofon izni gerekir."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Sesli mesaj kaydetmek icin mikrofon izni gerekir."
        }
      ]
    ],
    "platforms": [
      "android"
    ],
    "extra": {
      "eas": {
        "projectId": "43674389-3436-4e56-86b7-3f01df5a60b9"
      }
    },
    "owner": "beylerbeyi"
  }
}
