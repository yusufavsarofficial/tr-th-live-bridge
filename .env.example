PORT=3000
MAX_USERS=2
MAX_MESSAGE_LENGTH=500
MAX_HISTORY=120

# Optional room access controls
# ROOM_CODE=team-code
# ROOM_PIN=1234

# Optional persistence file path
DATA_FILE=./data/chat-history.json
NOTIFICATION_FILE=./data/notification-state.json
TRANSLATION_PROVIDER=openai-first
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
TRANSLATE_TIMEOUT_MS=7000

# Optional stable Web Push keys. If empty, Pingle generates and stores keys in NOTIFICATION_FILE.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:pingle@ayfsoft.com
