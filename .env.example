# ─── Server ───────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Authentication ────────────────────────────────────
JWT_SECRET=dev-jwt-secret-pingle-2026
# Only these numbers can log in (comma separated)
ALLOWED_USERS=+905514883842,+66642177978

# ─── Prisma / Database ─────────────────────────────────
# SQLite for local dev, PostgreSQL for production (Render)
DB_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# ─── SMS (Twilio) ──────────────────────────────────────
# Required for production OTP delivery. Get from twilio.com/console
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1234567890

# ─── Firebase Cloud Messaging ──────────────────────────
# Path to Firebase Admin SDK service account JSON (production only)
# FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Room limits ──────────────────────────────────────
MAX_USERS=2
MAX_MESSAGE_LENGTH=500
MAX_ATTACHMENT_BYTES=4500000
MAX_HISTORY=120

# ─── Optional room access ─────────────────────────────
# ROOM_CODE=secret-code
# ROOM_PIN=1234

# ─── Translation (OpenAI — set your own key) ──────────
# OPENAI_API_KEY=sk-...
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
TRANSLATION_PROVIDER=legacy
TRANSLATE_TIMEOUT_MS=7000

# ─── Web Push (VAPID) ─────────────────────────────────
# Set these in production so push survives deploys.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:nova@ayfsoft.com

# ─── WebRTC ICE servers ───────────────────────────────
# JSON array of ICE server objects. Default: Google STUN.
# Add TURN for reliable calls:
# RTC_ICE_SERVERS_JSON=[{"urls":"turn:your-turn-server.com:3478","username":"user","credential":"pass"}]

# ─── Call settings ────────────────────────────────────
CALL_OFFER_TTL_MS=90000
PUSH_TTL_SECONDS=604800

# ─── CORS ──────────────────────────────────────────────
CORS_ORIGIN=*
