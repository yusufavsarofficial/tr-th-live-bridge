{
  "name": "pingle",
  "version": "1.0.3",
  "description": "Pingle | private 2-person real-time chat",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "smoke": "node scripts/smoke-test.js",
    "test:rtc": "node scripts/rtc-signal-test.js",
    "pack:apk": "cd android && gradlew.bat assembleDebug",
    "desktop": "electron .",
    "pack:win": "electron-builder --win nsis",
    "pack:portable": "node scripts/pack-portable.js"
  },
  "keywords": [
    "chat",
    "socket.io",
    "pingle"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "openai": "^6.38.0",
    "socket.io": "^4.8.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "socket.io-client": "^4.8.3"
  },
  "build": {
    "appId": "com.pingle.chat",
    "productName": "Pingle",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "scripts/**/*",
      "server.js",
      "package.json",
      ".env.example",
      "README.md"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Pingle-Setup-${version}.${ext}"
    }
  }
}
